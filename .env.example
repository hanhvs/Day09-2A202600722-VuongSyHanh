# Chọn provider: openrouter | openai | anthropic | gemini | custom
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Custom OpenAI-compatible (Ollama, LM Studio, vLLM, ...)
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=not-needed
CUSTOM_LLM_MODEL=

# Service URLs
REGISTRY_URL=http://localhost:10000
CUSTOMER_AGENT_URL=http://localhost:10100
